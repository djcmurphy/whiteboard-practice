{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Whiteboard Practice Session Config",
  "description": "Configuration for a whiteboarding practice session",
  "type": "object",
  "required": ["problemType", "context", "spec", "evaluation"],
  "properties": {
    "problemType": {
      "type": "string",
      "enum": ["dsa", "system-design", "frontend", "backend", "fullstack", "mobile", "devops"],
      "description": "The category of problem being practiced"
    },
    "context": {
      "type": "object",
      "description": "Domain and context for the session",
      "properties": {
        "domain": {
          "type": "string",
          "enum": ["general", "fintech", "healthcare", "e-commerce", "saas", "gaming", "social"],
          "description": "Industry domain for the problem"
        },
        "focusAreas": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Specific areas to focus on within the domain"
        }
      }
    },
    "spec": {
      "type": "object",
      "description": "Problem specification and constraints",
      "properties": {
        "difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "topics": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "examples": [["arrays", "linked-lists", "trees", "graphs", "dp"]]
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Problem-specific constraints (e.g., 'no-recursion', 'o-n-space')"
        },
        "timeLimit": {
          "type": "number",
          "minimum": 5,
          "maximum": 120,
          "description": "Time limit in minutes"
        }
      }
    },
    "evaluation": {
      "type": "object",
      "description": "Evaluation criteria and priorities",
      "properties": {
        "allowedLanguages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priorities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "examples": [["correctness", "time-complexity", "space-complexity", "communication"]]
        },
        "criteria": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "weight": { "type": "number" },
              "description": { "type": "string" }
            }
          }
        }
      }
    }
  }
}